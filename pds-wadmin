cmd_wid_db() {
  local custom_query=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --query=*)
        custom_query="${1#*=}"
        shift
        ;;
      *)
        echo "ERROR: Unknown option: $1"
        exit 1
        ;;
    esac
  done

  if [ -z "$ENV" ] || [ "$ENV" = "wadmin" ]; then
    echo "ERROR: wid db requires environment context (use pds-wadmin-dev, pds-wadmin-stage, or pds-wadmin-prod)"
    exit 1
  fi

  if [ -n "$custom_query" ]; then
    cmd_nomad_exec_sqlite "$custom_query"
    return
  fi

  # Default: full neuro_identity_link dump with duplicate annotation.
  cmd_nomad_exec_sqlite "
SELECT
  nil.did,
  COALESCE(a.handle, '?') AS handle,
  CASE WHEN nil.isTestUser = 1 THEN nil.testUserJid ELSE nil.userJid END AS jid,
  nil.isTestUser,
  nil.linkedAt,
  nil.lastLoginAt,
  CASE WHEN cnt.n > 1 THEN '*** DUP (' || cnt.n || ')' ELSE '' END AS dup_flag
FROM neuro_identity_link nil
LEFT JOIN actor a ON a.did = nil.did
JOIN (
  SELECT did, COUNT(*) AS n FROM neuro_identity_link GROUP BY did
) cnt ON cnt.did = nil.did
ORDER BY nil.did, nil.linkedAt;
"
}

cmd_wid_check_db() {
  local did="$1"

  if [ -z "$did" ]; then
    echo "ERROR: DID is required"
    echo "Usage: $0 wid check-db <did>"
    exit 1
  fi

  # This command requires direct database access via Nomad
  if [ -z "$ENV" ] || [ "$ENV" = "wadmin" ]; then
    echo "ERROR: wid check-db requires environment context (use pds-wadmin-dev, pds-wadmin-stage, or pds-wadmin-prod)"
    exit 1
  fi

  echo "═══════════════════════════════════════════════════════════════"
  echo "Database Consistency Check: $did"
  echo "═══════════════════════════════════════════════════════════════"
  echo ""

  local issues_found=0

  # 1. Check actor table
  echo "1️⃣  Actor Table"
  echo "───────────────────────────────────────────────────────────────"
  local actor_result
  actor_result=$(cmd_nomad_exec_sqlite "SELECT did, handle, createdAt FROM actor WHERE did='$did';" 2>&1)

  if echo "$actor_result" | grep -q "$did"; then
    local handle
    local created
    handle=$(echo "$actor_result" | grep "$did" | awk '{print $2}')
    created=$(echo "$actor_result" | grep "$did" | awk '{print $3}')
    echo "✓ Actor record found"
    echo "  Handle: ${handle:--}"
    echo "  Created: ${created:--}"
  else
    echo "✗ Actor record NOT FOUND"
    ((issues_found++))
  fi
  echo ""

  # 2. Check account table
  echo "2️⃣  Account Table"
  echo "───────────────────────────────────────────────────────────────"
  local account_result
  account_result=$(cmd_nomad_exec_sqlite "SELECT did, email, emailConfirmedAt FROM account WHERE did='$did';" 2>&1)

  if echo "$account_result" | grep -q "$did"; then
    echo "✓ Account record found"
    local email
    local confirmed
    email=$(echo "$account_result" | grep "$did" | awk '{print $2}')
    confirmed=$(echo "$account_result" | grep "$did" | awk '{print $3}')
    echo "  Email: ${email:--}"
    echo "  Email Confirmed: ${confirmed:-No}"
  else
    echo "✗ Account record NOT FOUND"
    ((issues_found++))
  fi
  echo ""

  # 3. Check neuro_identity_link table
  echo "3️⃣  Neuro Identity Link Table"
  echo "───────────────────────────────────────────────────────────────"

  local nil_result
  nil_result=$(cmd_nomad_exec_sqlite "SELECT did, CASE WHEN isTestUser = 1 THEN testUserJid ELSE userJid END AS jid, isTestUser, linkedAt, lastLoginAt FROM neuro_identity_link WHERE did='$did';" 2>&1)

  if echo "$nil_result" | grep -q "$did"; then
    # Count how many records
    local count
    count=$(echo "$nil_result" | grep -c "$did" || echo "0")

    if [ "$count" -eq 1 ]; then
      echo "✓ One W ID link found (correct)"
      local jid
      local is_test
      local linked
      local last_login
      jid=$(echo "$nil_result" | grep "$did" | awk '{print $2}')
      is_test=$(echo "$nil_result" | grep "$did" | awk '{print $3}')
      linked=$(echo "$nil_result" | grep "$did" | awk '{print $4}')
      last_login=$(echo "$nil_result" | grep "$did" | awk '{print $5}')
      echo "  JID: ${jid:--}"
      echo "  Test User: ${is_test:-0}"
      echo "  Linked At: ${linked:--}"
      echo "  Last Login: ${last_login:--}"
    else
      echo "✗ DUPLICATE W ID links found: $count records"
      ((issues_found++))
      echo ""
      echo "Records:"
      echo "$nil_result" | grep "$did" | while read -r line; do
        local jid
        local linked
        jid=$(echo "$line" | awk '{print $2}')
        linked=$(echo "$line" | awk '{print $4}')
        echo "  - JID: ${jid:-N/A}, Linked: ${linked:-N/A}"
      done
    fi
  else
    echo "✗ W ID link NOT FOUND"
    echo "  This account exists but has no W ID mapping"
    ((issues_found++))
  fi
  echo ""

  # 4. Check for orphaned records
  echo "4️⃣  Orphan Check"
  echo "───────────────────────────────────────────────────────────────"

  # Check if actor exists but account doesn't
  local has_actor
  local has_account
  has_actor=0
  has_account=0

  if echo "$actor_result" | grep -q "$did"; then
    has_actor=1
  fi
  if echo "$account_result" | grep -q "$did"; then
    has_account=1
  fi

  if [ "$has_actor" -eq 1 ] && [ "$has_account" -eq 0 ]; then
    echo "✗ ORPHANED: Actor exists without Account record"
    ((issues_found++))
  elif [ "$has_actor" -eq 0 ] && [ "$has_account" -eq 1 ]; then
    echo "✗ ORPHANED: Account exists without Actor record"
    ((issues_found++))
  else
    echo "✓ No orphaned records detected"
  fi
  echo ""

  # 5. Summary
  echo "═══════════════════════════════════════════════════════════════"
  echo "Summary"
  echo "═══════════════════════════════════════════════════════════════"

  if [ $issues_found -eq 0 ]; then
    echo "Status: ✓ Database consistency check passed"
    echo "  All required records present and correctly linked"
  else
    echo "Status: ✗ Found $issues_found issue(s)"
    echo ""
    echo "Recommended Actions:"
    if [ "$has_actor" -eq 0 ]; then
      echo "  • Missing actor record - account may be corrupted"
    fi
    if [ "$has_account" -eq 0 ]; then
      echo "  • Missing account record - account may be corrupted"
    fi
    if ! echo "$nil_result" | grep -q "$did"; then
      echo "  • Missing W ID link - user cannot authenticate via W ID"
      echo "    Use: ./pds-wadmin wid update $did <jid>"
    fi
    local nil_count
    nil_count=$(echo "$nil_result" | grep -c "$did" || echo "0")
    if [ "$nil_count" -gt 1 ]; then
      echo "  • Duplicate W ID links - may cause authentication issues"
      echo "    Review with: ./pds-wadmin wid db --query=\"SELECT * FROM neuro_identity_link WHERE did='$did'\""
    fi
  fi
  echo "═══════════════════════════════════════════════════════════════"
}

cmd_wid_inventory() {
  local subcmd="$1"
  shift

  case "$subcmd" in
    load)
      cmd_wid_inventory_load "$@"
      ;;
    status)
      cmd_wid_inventory_status "$@"
      ;;
    *)
      echo "ERROR: Unknown inventory subcommand: $subcmd"
      echo "Usage: $0 wid inventory <load|status>"
      exit 1
      ;;
  esac
}

cmd_wid_inventory_load() {
  local json_file="$1"

  if [ -z "$json_file" ]; then
    echo "ERROR: JSON file required"
    echo "Usage: $0 wid inventory load <path-to-CreatedAccounts.json>"
    exit 1
  fi

  if [ ! -f "$json_file" ]; then
    echo "ERROR: File not found: $json_file"
    exit 1
  fi

  echo "═══════════════════════════════════════════════════════════════"
  echo "Loading WID Account Inventory"
  echo "═══════════════════════════════════════════════════════════════"
  echo ""
  echo "📄 Reading: $json_file"

  # Parse the CreatedAccounts.json format and transform to API format
  # Expected input format:
  # {
  #   "NrAccounts": 100,
  #   "Created": 1773236086,
  #   "Records": [
  #     {
  #       "AccountNr": 1,
  #       "UserName": "c368377a-0c6a-4efc-b4e1-002436730907",
  #       "OnboardingUrl": "obinfo:id.tagroot.io:...",
  #       "QrCodeUrl": "https://auth-dev.widentity.dev/QR/...",
  #       "QrCode": "C:\\ProgramData\\IoT Gateway\\Batch\\000000001.png"
  #     }
  #   ]
  # }

  # Transform to API format using jq
  local request_data
  request_data=$(jq '{
    accounts: [
      .Records[] | {
        did: .UserName,
        onboardingUrl: .OnboardingUrl,
        qrCodeUrl: .QrCodeUrl
      } + (if .PreferredHandle then {preferredHandle: .PreferredHandle} else {} end)
    ],
    batchName: ("batch-" + (.Created | tostring))
  }' "$json_file")

  local account_count
  account_count=$(echo "$request_data" | jq '.accounts | length')

  echo "📊 Accounts to load: $account_count"
  echo ""
  echo "Uploading to PDS..."

  # Call the API endpoint
  local response
  response=$(api_call "POST" "io.trustanchor.admin.loadInventory" "$request_data")

  if echo "$response" | jq -e '.error' > /dev/null 2>&1; then
    echo "❌ ERROR: Failed to load inventory"
    echo "$response" | jq -r '.message // .error'
    exit 1
  fi

  local loaded
  local skipped
  local total

  loaded=$(echo "$response" | jq -r '.loaded')
  skipped=$(echo "$response" | jq -r '.skipped')
  total=$(echo "$response" | jq -r '.total')

  echo ""
  echo "✅ Import complete!"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "   Loaded:  $loaded"
  echo "   Skipped: $skipped (duplicates)"
  echo "   Total:   $total"
}

cmd_wid_inventory_status() {
  echo "═══════════════════════════════════════════════════════════════"
  echo "WID Account Inventory Status"
  echo "═══════════════════════════════════════════════════════════════"
  echo ""
  echo "Querying PDS..."

  # Call the API endpoint
  local response
  response=$(api_call "GET" "io.trustanchor.admin.getInventoryStatus" "")

  if echo "$response" | jq -e '.error' > /dev/null 2>&1; then
    echo "❌ ERROR: Failed to get inventory status"
    echo "$response" | jq -r '.message // .error'
    exit 1
  fi

  local available
  local allocated
  local consumed
  local total

  available=$(echo "$response" | jq -r '.available')
  allocated=$(echo "$response" | jq -r '.allocated')
  consumed=$(echo "$response" | jq -r '.consumed')
  total=$(echo "$response" | jq -r '.total')

  echo "📦 Available:  $available  (ready to allocate)"
  echo "🔒 Allocated:  $allocated  (assigned to invitations)"
  echo "✓ Consumed:   $consumed  (activated accounts)"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📊 Total:      $total"
  echo ""

  # Show warning if inventory is low
  if [ "$available" -lt 100 ]; then
    echo "⚠️  WARNING: Inventory is low (< 100 available)"
    echo "   Consider loading more accounts"
  elif [ "$available" -lt 500 ]; then
    echo "ℹ️  NOTICE: Inventory is below recommended threshold (< 500)"
  else
    echo "✅ Inventory levels are healthy"
  fi
}

cmd_nomad_status() {
  check_nomad_auth

  local job_name
  job_name="$(get_nomad_job_name)"
  echo "Checking status for job: $job_name"
  echo ""

  nomad status -token="${NOMAD_TOKEN}" "$job_name"
}

cmd_nomad_logs() {
  local tail_lines=""
  local follow=false

  # Parse flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tail=*)
        tail_lines="${1#*=}"
        shift
        ;;
      --follow|-f)
        follow=true
        shift
        ;;
      *)
        echo "ERROR: Unknown option: $1"
        exit 1
        ;;
    esac
  done

  export NOMAD_ADDR="https://nomad.wsocial.cloud"
  check_nomad_auth

  local job_name
  job_name="$(get_nomad_job_name)"
  echo "Fetching logs for job: $job_name"

  # Get the running allocation ID
  local alloc_id
  alloc_id=$(nomad status -token="${NOMAD_TOKEN}" "$job_name" | grep -E "^[a-f0-9]{8}\s+" | grep "running" | head -n1 | awk '{print $1}')

  if [ -z "$alloc_id" ]; then
    echo "ERROR: No running allocation found for job $job_name"
    exit 1
  fi

  echo "Using allocation: $alloc_id"
  echo ""

  # Build log command
  local log_cmd="nomad alloc logs -token=\"${NOMAD_TOKEN}\""
  [ -n "$tail_lines" ] && log_cmd="$log_cmd -tail -n $tail_lines"
  [ "$follow" = true ] && log_cmd="$log_cmd -f"
  log_cmd="$log_cmd $alloc_id pds"

  # Execute
  eval "$log_cmd"
}

#
# GOAT COMMANDS
#

cmd_goat() {
  # Check if goat is available
  if ! command -v goat >/dev/null 2>&1; then
    echo "ERROR: 'goat' command not found in PATH"
    echo "Please install goat or ensure it is in your PATH"
    exit 1
  fi

  # Pass all arguments to goat
  # PDS_HOST and PDS_ADMIN_PASSWORD are already set by check_env()
  exec goat "$@"
}

#
# MAIN
#

main() {
  if [ $# -eq 0 ]; then
    usage
  fi

  check_env

  local category="$1"
  shift

  case "$category" in
    account)
      if [ $# -eq 0 ]; then
        echo "ERROR: Account command required"
        usage
      fi
      local cmd="$1"
      shift
      case "$cmd" in
        delete)
          cmd_account_delete "$@"
          ;;
        *)
          echo "ERROR: Unknown account command: $cmd"
          usage
          ;;
      esac
      ;;

    admin)
      if [ $# -eq 0 ]; then
        echo "ERROR: Admin command required"
        usage
      fi
      local cmd="$1"
      shift
      case "$cmd" in
        createIosTestUser|create-ios-test-user)
          cmd_admin_create_ios_test_user "$@"
          ;;
        *)
          echo "ERROR: Unknown admin command: $cmd"
          usage
          ;;
      esac
      ;;

    wid)
      if [ $# -eq 0 ]; then
        echo "ERROR: WID command required"
        usage
      fi
      local cmd="$1"
      shift
      case "$cmd" in
        list)
          cmd_wid_list
          ;;
        show)
          cmd_wid_show "$@"
          ;;
        update)
          cmd_wid_update "$@"
          ;;
        handle)
          cmd_wid_handle "$@"
          ;;
        check-handle)
          cmd_wid_check_handle "$@"
          ;;
        check-db)
          cmd_wid_check_db "$@"
          ;;
        inventory)
          cmd_wid_inventory "$@"
          ;;
        schema)
          cmd_wid_schema "$@"
          ;;
        db)
          cmd_wid_db "$@"
          ;;
        *)
          echo "ERROR: Unknown wid command: $cmd"
          usage
          ;;
      esac
      ;;

    transfer)
      if [ $# -eq 0 ]; then
        echo "ERROR: Transfer command required"
        usage
      fi
      local cmd="$1"
      shift
      case "$cmd" in
        rehome)
          cmd_transfer_rehome "$@"
          ;;
        *)
          echo "ERROR: Unknown transfer command: $cmd"
          usage
          ;;
      esac
      ;;

    invitation)
      if [ $# -eq 0 ]; then
        echo "ERROR: Invitation command required"
        usage
      fi
      local cmd="$1"
      shift
      case "$cmd" in
        create)
          cmd_invitation_create "$@"
          ;;
        list)
          cmd_invitation_list "$@"
          ;;
        stats)
          cmd_invitation_stats "$@"
          ;;
        show)
          cmd_invitation_show "$@"
          ;;
        revoke)
          cmd_invitation_revoke "$@"
          ;;
        purge)
          cmd_invitation_purge "$@"
          ;;
        *)
          echo "ERROR: Unknown invitation command: $cmd"
          usage
          ;;
      esac
      ;;

    nomad)
      if [ $# -eq 0 ]; then
        echo "ERROR: Nomad command required"
        usage
      fi
      local cmd="$1"
      shift
      case "$cmd" in
        status)
          cmd_nomad_status "$@"
          ;;
        logs)
          cmd_nomad_logs "$@"
          ;;
        *)
          echo "ERROR: Unknown nomad command: $cmd"
          usage
          ;;
      esac
      ;;

    goat)
      # Pass all remaining arguments to goat
      cmd_goat "$@"
      ;;

    help|--help|-h)
      usage
      ;;

    *)
      echo "ERROR: Unknown category: $category"
      usage
      ;;
  esac
}

main "$@"
