#
# WID COMMANDS
#

cmd_wid_list() {
  if [ -n "$ENV" ]; then
    # Nomad available — query DB directly for full accuracy
    cmd_nomad_exec_sqlite "
SELECT
  a.did,
  COALESCE(a.handle, '?')        AS handle,
  COALESCE(ac.email, '-')        AS email,
  COALESCE(
    CASE WHEN nil.isTestUser = 1 THEN nil.testUserJid ELSE nil.userJid END,
    '-'
  ) AS jid,
  nil.isTestUser,
  nil.linkedAt,
  CASE WHEN cnt.n > 1 THEN 'DUP(' || cnt.n || ')' ELSE '' END AS flags
FROM actor a
LEFT JOIN account ac ON ac.did = a.did
LEFT JOIN neuro_identity_link nil ON nil.did = a.did
LEFT JOIN (
  SELECT did, COUNT(*) AS n FROM neuro_identity_link GROUP BY did
) cnt ON cnt.did = a.did
ORDER BY a.handle, nil.linkedAt;
"
  else
    # No Nomad (plain pds-wadmin with env vars) — use API
    local response
    response=$(api_call "GET" "com.atproto.admin.listNeuroAccounts?limit=1000")
    # Handle API response format (unified jid field)
    echo "$response" | jq -r '
      ["DID", "HANDLE", "EMAIL", "JID", "LINKED_AT", "FLAGS"],
      (
        .accounts[] |
        . as $acct |
        # Normalize: if neuroLinks array exists use it, else wrap flat scalars
        (if (.neuroLinks | type) == "array" and (.neuroLinks | length) > 0
         then .neuroLinks
         else [{jid: .jid, isTestUser: (.isTestUser // 0), linkedAt: .linkedAt}]
         end) as $links |
        $links[] |
        [
          $acct.did,
          ($acct.handle // "-"),
          ($acct.email // "-"),
          (.jid // "-"),
          (.linkedAt // "-"),
          ([(if .isTestUser == 1 then "TEST" else empty end),
            (if ($acct.duplicateLinks // false) then "DUP" else empty end)] |
           join(",") | if . == "" then "-" else . end)
        ]
      ) | @tsv
    ' | column -t -s $'\t'
  fi
}

cmd_wid_show() {
  local did="$1"

  if [ -z "$did" ]; then
    echo "ERROR: DID is required"
    echo "Usage: $0 wid show <did>"
    exit 1
  fi

  local response
  response=$(api_call "GET" "com.atproto.admin.getNeuroLink?did=$did")

  if echo "$response" | jq -e '.error' > /dev/null 2>&1; then
    echo "ERROR: Failed to fetch account details"
    echo "$response" | jq -r '.message // .error'
    exit 1
  fi

  # Normalize: support both old API format (flat scalars) and new (neuroLinks array)
  echo "$response" | jq '
    # Build a normalized neuroLinks array regardless of API version
    (if (.neuroLinks | type) == "array"
     then .neuroLinks
     else [{jid: .jid,
             isTestUser: (.isTestUser // 0),
             linkedAt: .linkedAt, lastLoginAt: .lastLoginAt}]
     end) as $links |
    {
      "DID": .did,
      "Handle": .handle,
      "Email": (.email // "N/A"),
      "Duplicate links": (.duplicateLinks // (($links | length) > 1)),
      "Neuro links": [
        $links[] |
        {
          "JID (W ID)": (.jid // "—"),
          "Test user": .isTestUser,
          "Linked at": (.linkedAt // "N/A"),
          "Last login": (.lastLoginAt // "N/A")
        }
      ]
    }
  '
}

cmd_wid_update() {
  local did="$1"
  local new_jid="$2"

  if [ -z "$did" ] || [ -z "$new_jid" ]; then
    echo "ERROR: Both DID and new JID are required"
    echo "Usage: $0 wid update <did> <jid>"
    exit 1
  fi

  # Validate JID format (must contain @auth)
  if [[ ! "$new_jid" =~ @auth ]]; then
    echo "ERROR: Invalid JID format (must contain '@auth')"
    exit 1
  fi

  local data
  data=$(jq -n \
    --arg did "$did" \
    --arg newJid "$new_jid" \
    '{did: $did, newJid: $newJid}')

  local response
  response=$(api_call "POST" "com.atproto.admin.updateNeuroLink" "$data")

  if echo "$response" | jq -e '.error' > /dev/null 2>&1; then
    echo "ERROR: Failed to update W ID"
    echo "$response" | jq -r '.message // .error'
    exit 1
  fi

  echo "✓ Success!"
  echo "$response" | jq '
    {
      "DID": .did,
      "Old W ID": (.oldJid // "None"),
      "New W ID": .newJid,
      "Updated At": .updatedAt
    }
  '
}

cmd_wid_handle() {
  local did="$1"
  local new_handle="$2"

  if [ -z "$did" ] || [ -z "$new_handle" ]; then
    echo "ERROR: Both DID and new handle are required"
    echo "Usage: $0 wid handle <did> <new-handle>"
    exit 1
  fi

  # Validate handle format (basic check)
  if [[ ! "$new_handle" =~ \. ]]; then
    echo "ERROR: Handle must contain at least one dot (e.g. ingmar.wsocial.eu)"
    exit 1
  fi

  echo "Updating handle for $did"
  echo "  New handle: $new_handle"
  echo ""

  local data
  data=$(jq -n \
    --arg did "$did" \
    --arg handle "$new_handle" \
    '{did: $did, handle: $handle}')

  local response
  response=$(api_call "POST" "com.atproto.admin.updateAccountHandle" "$data")

  # updateAccountHandle returns 200 with empty body on success
  if echo "$response" | jq -e '.error' > /dev/null 2>&1; then
    echo "ERROR: Failed to update handle"
    echo "$response" | jq -r '.message // .error'
    exit 1
  fi

  echo "✓ Handle updated to: $new_handle"
  echo ""
  echo "Next steps:"
  echo "  1. Verify DNS TXT:  dig TXT _atproto.$new_handle +short"
  echo "  2. Verify well-known: curl https://$new_handle/.well-known/atproto-did"
  echo "  3. Verify resolve:  curl '${PDS_HOST}/xrpc/com.atproto.identity.resolveHandle?handle=$new_handle'"
}

cmd_wid_check_handle() {
  local handle="$1"

  if [ -z "$handle" ]; then
    echo "ERROR: Handle is required"
    echo "Usage: $0 wid check-handle <handle>"
    exit 1
  fi

  # Get AppView URL from Vault if we have an environment context
  local appview_url=""
  if [ -n "$ENV" ] && [ "$ENV" != "wadmin" ]; then
    appview_url=$(vault kv get -mount=secret -field BSKY_APP_VIEW_URL "pds/${ENV}" 2>/dev/null || echo "")
  fi

  echo "═══════════════════════════════════════════════════════════════"
  echo "Handle Resolution Check: $handle"
  echo "═══════════════════════════════════════════════════════════════"
  echo ""

  # 1. DNS TXT Record Check
  echo "1️⃣  DNS TXT Record (_atproto.$handle)"
  echo "───────────────────────────────────────────────────────────────"
  local dns_result
  dns_result=$(dig TXT "_atproto.$handle" +short 2>&1)

  if [ -n "$dns_result" ]; then
    echo "✓ Found DNS TXT record:"
    echo "$dns_result" | sed 's/^/  /'

    # Extract DID from DNS result
    local dns_did
    dns_did=$(echo "$dns_result" | grep -o 'did:plc:[a-z0-9]*' | head -n1)
    if [ -n "$dns_did" ]; then
      echo "  Extracted DID: $dns_did"
    fi
  else
    echo "✗ No DNS TXT record found"
    dns_did=""
  fi
  echo ""

  # 2. Well-Known HTTPS Check
  echo "2️⃣  Well-Known HTTPS (https://$handle/.well-known/atproto-did)"
  echo "───────────────────────────────────────────────────────────────"
  local wellknown_result
  local wellknown_status
  local wellknown_body

  # Disable exit-on-error for curl (handle failures gracefully)
  set +e
  wellknown_result=$(curl -sS -w "\nHTTP_STATUS:%{http_code}" "https://$handle/.well-known/atproto-did" 2>&1)
  local curl_exit=$?
  set -e

  if [ $curl_exit -ne 0 ]; then
    echo "✗ Well-known endpoint not accessible (connection failed)"
    echo "  Error: $(echo "$wellknown_result" | head -n 1)"
    wellknown_did=""
  else
    wellknown_status=$(echo "$wellknown_result" | grep "HTTP_STATUS:" | cut -d: -f2)
    wellknown_body=$(echo "$wellknown_result" | sed '/HTTP_STATUS:/d')

    if [ "$wellknown_status" = "200" ]; then
      echo "✓ Well-known endpoint accessible (HTTP $wellknown_status)"
      echo "  Content: $wellknown_body"

      # Validate it's a DID
      if [[ "$wellknown_body" =~ ^did:plc:[a-z0-9]+$ ]]; then
        echo "  Valid DID format: $wellknown_body"
        wellknown_did="$wellknown_body"
      else
        echo "  ⚠️  Response is not a valid DID"
        wellknown_did=""
      fi
    else
      echo "✗ Well-known endpoint failed (HTTP ${wellknown_status:-ERROR})"
      if [ -n "$wellknown_body" ]; then
        echo "  Error: $wellknown_body" | head -n 3
      fi
      wellknown_did=""
    fi
  fi
  echo ""

  # 3. PDS resolveHandle Check
  echo "3️⃣  PDS resolveHandle (${PDS_HOST}/xrpc/com.atproto.identity.resolveHandle)"
  echo "───────────────────────────────────────────────────────────────"
  local resolve_result
  local resolved_did=""

  # Disable exit-on-error for curl (handle failures gracefully)
  set +e
  resolve_result=$(curl -sS "${PDS_HOST}/xrpc/com.atproto.identity.resolveHandle?handle=$handle" 2>&1)
  local curl_exit=$?
  set -e

  if [ $curl_exit -ne 0 ]; then
    echo "✗ PDS resolution failed (connection error)"
    echo "  Error: $(echo "$resolve_result" | head -n 1)"
  elif echo "$resolve_result" | jq -e '.did' > /dev/null 2>&1; then
    resolved_did=$(echo "$resolve_result" | jq -r '.did')
    echo "✓ PDS resolved handle successfully"
    echo "  Resolved DID: $resolved_did"
  else
    echo "✗ PDS resolution failed"
    if echo "$resolve_result" | jq -e '.error' > /dev/null 2>&1; then
      echo "  Error: $(echo "$resolve_result" | jq -r '.message // .error')"
    else
      echo "  Raw response: $resolve_result" | head -n 3
    fi
  fi
  echo ""

  # 4. AppView resolveHandle Check (only if AppView URL is configured)
  local appview_did=""
  if [ -n "$appview_url" ]; then
    echo "4️⃣  AppView resolveHandle (${appview_url}/xrpc/com.atproto.identity.resolveHandle)"
    echo "───────────────────────────────────────────────────────────────"
    local appview_result

    # Disable exit-on-error for curl (handle failures gracefully)
    set +e
    appview_result=$(curl -sS "${appview_url}/xrpc/com.atproto.identity.resolveHandle?handle=$handle" 2>&1)
    local curl_exit=$?
    set -e

    if [ $curl_exit -ne 0 ]; then
      echo "✗ AppView resolution failed (connection error)"
      echo "  Error: $(echo "$appview_result" | head -n 1)"
    elif echo "$appview_result" | jq -e '.did' > /dev/null 2>&1; then
      appview_did=$(echo "$appview_result" | jq -r '.did')
      echo "✓ AppView resolved handle successfully"
      echo "  Resolved DID: $appview_did"
    else
      echo "✗ AppView resolution failed"
      if echo "$appview_result" | jq -e '.error' > /dev/null 2>&1; then
        echo "  Error: $(echo "$appview_result" | jq -r '.message // .error')"
      else
        echo "  Raw response: $appview_result" | head -n 3
      fi
    fi
    echo ""
  else
    echo "4️⃣  AppView resolveHandle"
    echo "───────────────────────────────────────────────────────────────"
    echo "⊘ Skipped (BSKY_APP_VIEW_URL not configured in Vault)"
    echo ""
  fi

  # 5. Summary
  echo "═══════════════════════════════════════════════════════════════"
  echo "Summary"
  echo "═══════════════════════════════════════════════════════════════"

  # For handle verification, we need EITHER DNS TXT OR well-known (not both)
  local handle_method_ok=false
  local has_both=false

  if [ -n "$dns_did" ] && [ -n "$wellknown_did" ]; then
    has_both=true
    handle_method_ok=true  # Works, but unusual
  elif [ -n "$dns_did" ] || [ -n "$wellknown_did" ]; then
    handle_method_ok=true
  fi

  # Check if all required checks passed
  local all_required_passed=false
  if [ "$handle_method_ok" = true ] && [ -n "$resolved_did" ]; then
    all_required_passed=true
  fi

  # If AppView was checked, require it to pass too
  local all_checks_passed=false
  if [ "$all_required_passed" = true ]; then
    if [ -n "$appview_url" ]; then
      # AppView is configured, so require it to pass
      if [ -n "$appview_did" ]; then
        all_checks_passed=true
      fi
    else
      # AppView not configured, so all required checks passing is sufficient
      all_checks_passed=true
    fi
  fi

  if [ "$all_checks_passed" = true ]; then
    echo "Status: ✓ All checks passed"
    echo ""

    # Determine which DID to use as reference (prefer DNS, then well-known)
    local reference_did="${dns_did:-$wellknown_did}"

    # Check if all DIDs match (including AppView if checked)
    local all_match=true
    if [ -n "$dns_did" ] && [ "$dns_did" != "$reference_did" ]; then
      all_match=false
    fi
    if [ -n "$wellknown_did" ] && [ "$wellknown_did" != "$reference_did" ]; then
      all_match=false
    fi
    if [ "$resolved_did" != "$reference_did" ]; then
      all_match=false
    fi
    if [ -n "$appview_did" ] && [ "$appview_did" != "$reference_did" ]; then
      all_match=false
    fi

    if [ "$all_match" = true ]; then
      echo "DID Consistency: ✓ All methods return same DID"
      echo "  DID: $reference_did"

      # Warn if both handle methods are present
      if [ "$has_both" = true ]; then
        echo ""
        echo "⚠️  Note: Both DNS TXT and well-known are configured"
        echo "    This is unusual - typically handles use one method or the other"
      fi
    else
      echo "DID Consistency: ✗ MISMATCH DETECTED"
      if [ -n "$dns_did" ]; then
        echo "  DNS TXT:      $dns_did"
      fi
      if [ -n "$wellknown_did" ]; then
        echo "  Well-Known:   $wellknown_did"
      fi
      echo "  PDS Resolve:  ${resolved_did:-N/A}"
      if [ -n "$appview_url" ]; then
        echo "  AppView:      ${appview_did:-N/A}"
      fi
    fi
  else
    echo "Status: ✗ Some checks failed"
    echo ""
    echo "Results:"
    if [ -n "$dns_did" ]; then
      echo "  DNS TXT:      ✓ $dns_did"
    elif [ -n "$wellknown_did" ]; then
      echo "  DNS TXT:      ⊘ Not used (well-known configured instead)"
    else
      echo "  DNS TXT:      ✗ Not found"
    fi

    if [ -n "$wellknown_did" ]; then
      echo "  Well-Known:   ✓ $wellknown_did"
    elif [ -n "$dns_did" ]; then
      echo "  Well-Known:   ⊘ Not used (DNS TXT configured instead)"
    else
      echo "  Well-Known:   ✗ Not accessible"
    fi

    echo "  PDS Resolve:  $([ -n "$resolved_did" ] && echo "✓ $resolved_did" || echo "✗ Failed")"
    if [ -n "$appview_url" ]; then
      echo "  AppView:      $([ -n "$appview_did" ] && echo "✓ $appview_did" || echo "✗ Failed")"
    else
      echo "  AppView:      ⊘ Skipped (not configured)"
    fi

    # Warn if both handle methods are present
    if [ "$has_both" = true ]; then
      echo ""
      echo "⚠️  Note: Both DNS TXT and well-known are configured"
      echo "    This is unusual - typically handles use one method or the other"
    fi

    echo ""
    echo "Troubleshooting:"
    if [ "$handle_method_ok" = false ]; then
      echo "  • No handle verification method found - need either:"
      echo "    - DNS TXT record at _atproto.$handle, OR"
      echo "    - HTTPS endpoint at https://$handle/.well-known/atproto-did"
    fi
    if [ -z "$resolved_did" ]; then
      echo "  • PDS cannot resolve handle - may need to refresh identity cache"
    fi
    if [ -n "$appview_url" ] && [ -z "$appview_did" ]; then
      echo "  • AppView cannot resolve handle - account may not be indexed yet"
      echo "    (AppView syncs from PDS; check if account creation was recent)"
    fi
  fi
  echo "═══════════════════════════════════════════════════════════════"
}

