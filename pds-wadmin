# Make API call to PDS
api_call() {
  local method="$1"
  local endpoint="$2"
  local data="${3:-}"

  local url="${PDS_HOST}/xrpc/${endpoint}"

  if [ "$method" = "GET" ]; then
    curl -s --user "admin:${PDS_ADMIN_PASSWORD}" \
      "$url" 2>&1
  else
    curl -s --user "admin:${PDS_ADMIN_PASSWORD}" \
      -X "$method" \
      -H "Content-Type: application/json" \
      -d "$data" \
      "$url" 2>&1
  fi
}

#
# ACCOUNT COMMANDS
#

cmd_account_delete() {
  local did="$1"

  if [ -z "$did" ]; then
    echo "ERROR: DID is required"
    echo "Usage: $0 account delete <did>"
    exit 1
  fi

  # Fetch account details first
  echo "Fetching account details..."
  echo ""

  local account_info
  account_info=$(api_call "GET" "com.atproto.admin.getNeuroLink?did=$did" 2>&1)

  if echo "$account_info" | jq -e '.error' > /dev/null 2>&1; then
    echo "ERROR: Failed to fetch account details"
    echo "$account_info" | jq -r '.message // .error'
    exit 1
  fi

  # Display account info
  echo "Account to be deleted:"
  echo "====================="
  echo "$account_info" | jq -r '
    "DID:     \(.did)",
    "Handle:  \(.handle // "N/A")",
    "Email:   \(.email // "N/A")"
  '
  echo ""

  # Confirmation prompt
  echo "⚠️  WARNING: This will PERMANENTLY delete the account and all associated data:"
  echo "   - Account record"
  echo "   - Actor record"
  echo "   - Repository data"
  echo "   - Email tokens"
  echo "   - Refresh tokens"
  echo "   - Neuro identity links (W ID)"
  echo "   - All user data from sequencer"
  echo ""
  read -p "Type the handle to confirm deletion: " confirm_handle

  local actual_handle
  actual_handle=$(echo "$account_info" | jq -r '.handle // ""')

  if [ "$confirm_handle" != "$actual_handle" ]; then
    echo "ERROR: Handle mismatch. Deletion cancelled."
    exit 1
  fi

  echo ""
  echo "Deleting account..."

  local data
  data=$(jq -n --arg did "$did" '{did: $did}')

  local response
  response=$(api_call "POST" "com.atproto.admin.deleteAccount" "$data")

  if echo "$response" | jq -e '.error' > /dev/null 2>&1; then
    echo "ERROR: Failed to delete account"
    echo "$response" | jq -r '.message // .error'
    exit 1
  fi

  echo "✓ Account deleted successfully"
  echo "  DID: $did"
  echo "  Handle: $actual_handle"
}

